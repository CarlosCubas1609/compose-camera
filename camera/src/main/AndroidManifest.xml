<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- CAMERA y RECORD_AUDIO son los únicos permisos necesarios:
         PickVisualMedia (API 33+) y READ_MEDIA_VISUAL_USER_SELECTED (API 34+) no requieren
         que la librería declare READ_MEDIA_IMAGES/VIDEO. Google Play rechaza esos permisos
         si el caso de uso no es acceso persistente a la galería (policy "core use case"). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_MEDIA_VISUAL_USER_SELECTED" />

</manifest>
